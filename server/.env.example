# ---- Dukaan Saathi backend configuration ----------------------------------
# Copy this file to `.env` and fill in the keys you have. Everything degrades
# gracefully: with NO keys at all, the Dukaan Saathi AI chat + dashboard still
# work using a built-in rule-based parser ("Demo AI Mode"; voice via browser).

# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# NVIDIA NIM (message understanding + coach insights). A valid nvapi-… key
# enables "Live AI". Without it the app runs in "Demo AI Mode" (rule-based parser).
NVIDIA_API_KEY=
# Model name on the NVIDIA NIM API
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
# Base URL for the OpenAI-compatible NVIDIA NIM endpoint
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=16384
NVIDIA_REASONING_BUDGET=16384

# Sarvam AI (voice note -> text). Optional — the browser's speech API is the
# primary path; Sarvam is a server-side fallback. Without it, voice still works
# in browsers that support the Web Speech API.
SARVAM_API_KEY=
# Sarvam STT model + endpoint (override only if the API changes)
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
