# ---- Dukaan Saathi backend configuration ----------------------------------
# Copy this file to `.env` and fill in the keys you have. Everything degrades
# gracefully: with NO keys at all, the web simulator + dashboard still work
# using a built-in rule-based parser (voice disabled).

# Server
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Claude (message understanding). Without this, a rule-based mock parser is used.
ANTHROPIC_API_KEY=
# Model used for parsing. Sonnet-class recommended for reliable Telugu extraction.
CLAUDE_MODEL=claude-sonnet-5

# Sarvam AI (voice note -> text). Without this, voice notes reply "not enabled".
SARVAM_API_KEY=
# Sarvam STT model + endpoint (override only if the API changes)
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text

# Twilio WhatsApp (real WhatsApp channel). Without this, only the simulator runs.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your Twilio sandbox / WhatsApp sender, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Verify Twilio's request signature on the webhook (recommended in production;
# requires the public webhook URL to match exactly). Leave off for local demos.
VALIDATE_TWILIO_SIGNATURE=false
